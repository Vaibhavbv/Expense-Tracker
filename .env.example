# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings -> API). NEVER commit the real `.env` file.

# Your Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=your-supabase-url

# The public "anon" key (safe for the browser; RLS enforces access rules)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OPTIONAL: the public URL auth emails (confirm signup / reset password) should
# link back to. Leave unset locally to use the current origin; set it in Vercel
# to your production domain, e.g. https://your-app.vercel.app
# VITE_SITE_URL=https://your-app.vercel.app
